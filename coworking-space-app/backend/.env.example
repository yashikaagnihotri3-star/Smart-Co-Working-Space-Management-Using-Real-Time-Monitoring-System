# Server
PORT=5000
NODE_ENV=development

# SQLite database file path (optional - defaults to backend/data/coworking.sqlite)
# DB_STORAGE=./data/coworking.sqlite

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend origin (for CORS)
CLIENT_ORIGIN=http://localhost:5173
